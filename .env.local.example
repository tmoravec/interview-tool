# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: override the default model (default: google/gemini-2.5-pro-exp-03-25:free)
# MODEL=google/gemini-2.5-flash-preview

# Optional: password to protect the app (leave unset to disable auth)
# APP_PASSWORD=your-secret-password-here

# Optional: enable verbose server-side logging (default: false)
# DEBUG=false
